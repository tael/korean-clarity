---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = '한국어 명료성 도구', description = 'AI가 쓴 듯한 한국어를 잡아내는 룰 기반 분석기와 지침' } = Astro.props;
const base = import.meta.env.BASE_URL;
---
<!doctype html>
<html lang="ko">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <title>{title}</title>
</head>
<body>
  <div class="wrap">
    <header class="site">
      <h1><a href={base}>한국어 명료성 도구 <small>korean-clarity</small></a></h1>
      <nav>
        <a href={base}>분석기</a>
        <a href={`${base}docs/`}>지침</a>
        <a href="https://github.com/" target="_blank" rel="noopener">GitHub</a>
      </nav>
    </header>
    <slot />
  </div>
</body>
</html>
