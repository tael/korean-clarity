  "files": ["dist", "src", "data"],
  "scripts": {
    "build": "tsc",
    "test": "node --test --import=tsx tests/analyze.test.ts tests/eval.test.ts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "license": "MIT"
}
