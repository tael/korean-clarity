{
  "name": "@korean-clarity/analyzer",
  "version": "0.1.0",
  "description": "한국어 명료성·AI 클리셰 룰 기반 분석기",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
